/* ════════════════════════════════════════
   PARTICLES — FALLING STARS
   ════════════════════════════════════════ */

.particles-container {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}

@keyframes float-particle {
  0%   { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
  15%  { opacity: 1; }
  85%  { opacity: 1; }
  100% { transform: translateY(105vh) rotate(360deg); opacity: 0; }
}

/* ── Mặc định: vàng nhạt ── */
.p {
  position: absolute;
  top: -50px;
  color: #FFFACD;
  text-shadow: 0 0 8px #FFD700, 0 0 18px #FFFACD;
  animation: float-particle 8s linear infinite;
  transition: color 0.8s ease, text-shadow 0.8s ease;
}

.p::before         { content: "⚝"; font-size: 1.1rem; }
.p:nth-child(3n)::before { content: "✧"; }
.p:nth-child(5n)::before { content: "♡"; }

/* ── Dark Rose: trắng phát sáng hồng ── */
body:has(.wine-toggle[open]) .p {
  color: #ffffff;
