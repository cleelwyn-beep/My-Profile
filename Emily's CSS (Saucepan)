          <span class="s-title"><span class="s-title-icon">✦</span>Lorebooks</span>
          <span class="s-count">{{total_lorebook_count}} tomes</span>
        </div>
        <div class="lorebooks-grid">
          {{#each paginated_lorebooks}}
          <div class="lb-card" tabindex="0">
            <div class="lb-card-inner">
              <div class="lb-front">
                <img src="{{image}}" alt="{{name}}">
                <div class="lb-front-info">
                  <div class="lb-front-name">{{name}}</div>
                  <div class="lb-front-desc">{{description}}</div>
                </div>
              </div>
              <div class="lb-back">
                <div class="lb-back-name">{{name}}</div>
                <div class="lb-back-tags">
                  {{#each tags}}<span class="c-tag" saucepan-tag="{{this}}">{{this}}</span>{{/each}}
                </div>
                <a class="lb-view-link" href="{{url}}">Read ✦</a>
                <a class="lb-fav-link" saucepan-trigger-lorebook-favorite="{{id}}">
                  {{#if is_favorited}}♦ Unfavorite{{else}}♢ Favorite{{/if}}
                </a>
              </div>
            </div>
          </div>
          {{/each}}
        </div>
        {{#if paginated_lorebooks_page_numbers}}
        <div class="pagination">
          {{#each paginated_lorebooks_page_numbers}}
          <a class="pag-link{{#if is_current}} current{{/if}}" saucepan-trigger-lorebooks-pagination="{{number}}">{{number}}</a>
          {{/each}}
        </div>
        {{/if}}
      </section>

      <section>
        <div class="s-header">
          <span class="s-title"><span class="s-title-icon">✦</span>Collections</span>
          <span class="s-count">{{total_collection_count}} archives</span>
        </div>
        <div class="collections-grid">
          {{#each paginated_collections}}
          <div class="col-card" tabindex="0">
            <div class="col-card-inner">
              <div class="col-front">
                <img src="{{image}}" alt="{{name}}">
                <div class="col-front-info">
                  <div class="col-front-name">{{name}}</div>
                  <div class="col-front-count">{{companion_count}} companions</div>
                </div>
              </div>
              <div class="col-back">
                <div class="col-back-name">{{name}}</div>
                <div class="col-back-desc">{{description}}</div>
                <div class="col-back-tags">
                  {{#each tags}}<span class="c-tag" saucepan-tag="{{this}}">{{this}}</span>{{/each}}
                </div>
                <a class="col-view-link" href="{{url}}">View ✦</a>
                <a class="col-fav-link" saucepan-trigger-collection-favorite="{{id}}">
                  {{#if is_favorited}}♦ Unfavorite{{else}}♢ Favorite{{/if}}
                </a>
              </div>
            </div>
          </div>
          {{/each}}
        </div>
        {{#if paginated_collections_page_numbers}}
        <div class="pagination">
          {{#each paginated_collections_page_numbers}}
          <a class="pag-link{{#if is_current}} current{{/if}}" saucepan-trigger-collections-pagination="{{number}}">{{number}}</a>
          {{/each}}
        </div>
        {{/if}}
      </section>

      <section>
        <div class="s-header">
          <span class="s-title"><span class="s-title-icon">✦</span>Posts</span>
          <span class="s-count">{{total_posts}} entries</span>
        </div>
        <div class="posts-list">
          {{#each posts}}
          <div class="post-card">
            {{#if image}}
            <img class="post-img" src="{{image}}" alt="{{title}}">
            {{else}}
            <div class="post-img-placeholder">✦</div>
            {{/if}}
            <div class="post-body">
              <span class="post-date">{{posted_at}}</span>
              <a class="post-title-link" href="{{url}}">{{title}}</a>
              {{#if blurb}}<p class="post-blurb">{{blurb}}</p>{{/if}}
              <div class="post-tags">
                {{#each tags}}<span class="post-tag">{{this}}</span>{{/each}}
              </div>
            </div>
          </div>
          {{/each}}
        </div>
        {{#if paginated_posts_page_numbers}}
        <div class="pagination">
          {{#each paginated_posts_page_numbers}}
          <a class="pag-link{{#if is_current}} current{{/if}}" saucepan-trigger-posts-pagination="{{number}}">{{number}}</a>
          {{/each}}
        </div>
        {{/if}}
      </section>

    </main>
  </div>

