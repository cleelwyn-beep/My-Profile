<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Umbral Court — Style Script Edition</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cookie&family=Pinyon+Script&family=Style+Script&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Sofia&display=swap');

/* ═══════════════════════════
   ROOT VARIABLES — SOFT PINK + IVORY
═══════════════════════════ */
:root {
  --ink:       #1a0d10;
  --void:      #1c0f14;
  --deep:      #221218;
  --crypt:     #2e1520;
  --dusk:      #3d1a28;
  --amethyst:  #b05070;
  --violet:    #c8607a;
  --lavender:  #e8a0b0;
  --ghost:     #f2d8dc;
  --silver:    #faf0f0;
  --glow:      rgba(200,96,122,0.5);
  --glow-dim:  rgba(200,96,122,0.15);
  --border:    rgba(200,96,122,0.28);
  --border-hi: rgba(232,160,176,0.6);
  --ivory:     #f7f0e6;
  --ivory-dim: rgba(247,240,230,0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body, .page-root {
  background-color: var(--void);
  color: var(--ghost);
  font-family: 'Crimson Text', Georgia, serif;
  font-size: 16px;
  line-height: 1.6;
  overflow-x: hidden;
}

.page-root {
  background-image:
    radial-gradient(ellipse 70% 50% at 15% 30%, rgba(180,60,90,0.15) 0%, transparent 60%),
    radial-gradient(ellipse 60% 60% at 85% 70%, rgba(160,50,80,0.12) 0%, transparent 55%),
    radial-gradient(ellipse 100% 40% at 50% 100%, rgba(200,120,140,0.12) 0%, transparent 50%),
    radial-gradient(ellipse 120% 60% at 50% 0%, rgba(247,240,230,0.04) 0%, transparent 55%),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(200,96,122,0.012) 2px,
      rgba(200,96,122,0.012) 4px
    );
  min-height: 100vh;
}

/* ═══════════════════════════
   BANNER
═══════════════════════════ */
.profile-banner {
  width: 100%;
  height: 260px;
  background-color: #2a1018;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(247,220,225,0.3);
  box-shadow: 0 0 28px rgba(180,60,90,0.25);
}

.banner-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  z-index: 0;
}

.profile-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(28,15,20,0.2) 0%,
    rgba(28,15,20,0.38) 50%,
    rgba(28,15,20,0.88) 88%,
    var(--void) 100%
  );
  z-index: 1;
}

.banner-vignette {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 100% at 50% 100%, transparent 20%, rgba(28,15,20,0.95) 80%),
    linear-gradient(to bottom, transparent 50%, rgba(28,15,20,0.98) 100%);
  z-index: 2;
}

.banner-ornament-row {
  position: absolute;
  bottom: 18px;
  left: 0; right: 0;
  text-align: center;
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  color: rgba(242,210,215,0.7);
  font-family: 'Style Script', cursive;
  pointer-events: none;
  z-index: 3;
}

.banner-corner {
  position: absolute;
  width: 40px; height: 40px;
  opacity: 0.4;
  z-index: 3;
}
.banner-corner-tl { top: 12px; left: 14px; border-top: 1px solid var(--violet); border-left: 1px solid var(--violet); }
.banner-corner-tr { top: 12px; right: 14px; border-top: 1px solid var(--violet); border-right: 1px solid var(--violet); }

/* ═══════════════════════════
   MAIN LAYOUT
═══════════════════════════ */
.page-layout {
  display: grid;
  grid-template-columns: 268px 1fr;
  gap: 28px;
  max-width: 1280px;
  margin: 0 auto;
  padding: 40px 20px 80px;
}

/* ═══════════════════════════
   SIDEBAR
═══════════════════════════ */
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: -50px;
  position: relative;
  z-index: 10;
}

.g-panel {
  background: linear-gradient(155deg, var(--deep) 0%, var(--crypt) 100%);
  border: 1px solid var(--border);
  border-radius: 1px;
  position: relative;
  overflow: hidden;
}

.g-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 12%; right: 12%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--violet), rgba(247,240,230,0.4), var(--violet), transparent);
}

.g-panel::after {
  content: '';
  position: absolute;
  bottom: 0; left: 12%; right: 12%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,96,122,0.18), transparent);
}

/* ── IDENTITY BLOCK ── */
.identity-block {
  padding: 22px 16px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.id-corner { position: absolute; width: 18px; height: 18px; }
.id-corner-tl { top: 8px; left: 8px; border-top: 1px solid rgba(200,96,122,0.4); border-left: 1px solid rgba(200,96,122,0.4); }
.id-corner-tr { top: 8px; right: 8px; border-top: 1px solid rgba(200,96,122,0.4); border-right: 1px solid rgba(200,96,122,0.4); }
.id-corner-bl { bottom: 8px; left: 8px; border-bottom: 1px solid rgba(200,96,122,0.2); border-left: 1px solid rgba(200,96,122,0.2); }
.id-corner-br { bottom: 8px; right: 8px; border-bottom: 1px solid rgba(200,96,122,0.2); border-right: 1px solid rgba(200,96,122,0.2); }

.avatar-wrap {
  width: 108px; height: 108px;
  border-radius: 50%;
  border: 1px solid var(--border-hi);
  box-shadow:
    0 0 0 4px rgba(200,96,122,0.07),
    0 0 24px var(--glow),
    0 0 60px rgba(180,60,90,0.18),
    0 0 0 8px rgba(247,240,230,0.03);
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.avatar-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

.avatar-halo {
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1px solid rgba(200,96,122,0.2);
  pointer-events: none;
  animation: halo-rotate 12s linear infinite;
}

@keyframes halo-rotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ── REAL NAME (Imperial Script) ── */
.id-real-name {
  font-family: 'Pinyon Script', cursive;
  font-size: 2rem;
  color: var(--lavender);
  text-align: center;
  text-shadow: 0 0 24px var(--glow), 0 0 48px rgba(200,96,122,0.3);
  letter-spacing: 0.04em;
  line-height: 1.2;
}

/* Style Script for handle */
.id-handle {
  font-family: 'Style Script', cursive;
  font-size: 1.3rem;
  letter-spacing: 0.04em;
  color: var(--lavender);
  text-align: center;
  text-shadow: 0 0 20px var(--glow);
}

.id-handle-deco {
  color: var(--violet);
  font-size: 0.9rem;
}

/* Style Script for description */
.id-description {
  font-family: 'Style Script', cursive;
  font-size: 1rem;
  color: var(--amethyst);
  text-align: center;
  line-height: 1.55;
  padding: 0 4px;
}

.id-stats {
  display: flex;
  gap: 16px;
  justify-content: center;
  width: 100%;
  padding: 6px 0;
  border-top: 1px solid rgba(200,96,122,0.12);
  border-bottom: 1px solid rgba(200,96,122,0.12);
}

.id-stat { text-align: center; }

.id-stat-val {
  display: block;
  font-family: 'Style Script', cursive;
  font-size: 1.1rem;
  color: var(--lavender);
}

.id-stat-label {
  font-family: 'Style Script', cursive;
  font-size: 0.85rem;
  color: var(--amethyst);
}

.id-follow-btn {
  display: block;
  width: 100%;
  padding: 8px 12px;
  text-align: center;
  background: linear-gradient(135deg, var(--dusk), rgba(160,40,70,0.8));
  border: 1px solid rgba(200,96,122,0.55);
  color: var(--lavender);
  font-family: 'Style Script', cursive;
  font-size: 1rem;
  letter-spacing: 0.06em;
  text-decoration: none;
  cursor: pointer;
  border-radius: 1px;
  transition: background 0.3s, box-shadow 0.3s, color 0.3s;
}

.id-follow-btn:hover {
  background: linear-gradient(135deg, rgba(160,40,70,0.9), rgba(200,80,110,0.9));
  box-shadow: 0 0 18px var(--glow);
  color: var(--silver);
}

.id-menu-btn {
  display: block;
  width: 100%;
  padding: 5px;
  text-align: center;
  background: transparent;
  border: 1px solid rgba(200,96,122,0.15);
  color: rgba(200,96,122,0.5);
  font-family: 'Style Script', cursive;
  font-size: 0.9rem;
  text-decoration: none;
  cursor: pointer;
  border-radius: 1px;
  transition: all 0.2s;
  letter-spacing: 0.04em;
}

.id-menu-btn:hover {
  color: var(--lavender);
  border-color: var(--border);
}

/* ── DROPDOWN PANELS ── */
.g-details { border: none; }

.g-details summary {
  list-style: none;
  padding: 11px 16px;
  /* ↓ Cookie font for panel headings: Elsewhere, About */
  font-family: 'Cookie', cursive;
  font-size: 1.15rem;
  letter-spacing: 0.06em;
  color: var(--lavender);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: color 0.2s;
  user-select: none;
}

.g-details summary:hover { color: var(--silver); }
.g-details summary::-webkit-details-marker { display: none; }

.g-details-arrow {
  margin-left: auto;
  font-size: 0.75rem;
  color: var(--violet);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  display: inline-block;
  font-family: 'Crimson Text', serif;
}

.g-details[open] .g-details-arrow { transform: rotate(180deg); }

.g-details-icon { color: var(--violet); font-size: 0.65rem; }

.g-details-body {
  padding: 4px 16px 14px;
  border-top: 1px solid rgba(200,96,122,0.12);
  animation: expand-in 0.25s ease;
}

@keyframes expand-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.social-link {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Sofia', cursive;
  font-size: 0.85rem;
  color: var(--amethyst);
  text-decoration: none;
  padding: 4px 0;
  border-bottom: 1px solid rgba(200,96,122,0.06);
  transition: color 0.2s, padding-left 0.25s;
}

.social-link:last-child { border-bottom: none; }
.social-link:hover { color: var(--lavender); padding-left: 8px; }

.social-link-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--violet);
  flex-shrink: 0;
  transition: box-shadow 0.2s;
}
.social-link:hover .social-link-dot { box-shadow: 0 0 6px var(--glow); }

.info-row {
  display: flex;
  gap: 10px;
  align-items: baseline;
  padding: 4px 0;
  border-bottom: 1px solid rgba(200,96,122,0.06);
}
.info-row:last-child { border-bottom: none; }

.info-key {
  font-family: 'Sofia', cursive;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: rgba(200,96,122,0.75);
  min-width: 62px;
  padding-top: 2px;
  flex-shrink: 0;
}

.info-val {
  font-family: 'Sofia', cursive;
  font-size: 0.85rem;
  color: var(--lavender);
  line-height: 1.4;
}

/* ── SCHEDULE PANEL ── */
.sched-panel { padding: 16px; }

.sched-heading {
  /* ↓ Cookie font for panel headings: Schedule, Creators I Love */
  font-family: 'Cookie', cursive;
  font-size: 1.15rem;
  letter-spacing: 0.06em;
  color: var(--lavender);
  margin-bottom: 10px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(200,96,122,0.2);
  display: flex;
  align-items: center;
  gap: 8px;
}

.sched-heading-icon { color: var(--violet); }

.sched-item {
  display: grid;
  grid-template-columns: 10px 1fr;
  gap: 8px;
  align-items: start;
  padding: 5px 0;
  border-bottom: 1px solid rgba(200,96,122,0.06);
}
.sched-item:last-child { border-bottom: none; }

.sched-bullet { color: var(--violet); font-size: 0.55rem; padding-top: 4px; }

.sched-text {
  font-family: 'Sofia', cursive;
  font-size: 0.82rem;
  color: rgba(232,160,176,0.75);
  line-height: 1.5;
}

.sched-text-bold { color: var(--lavender); font-weight: 600; }

.sched-divider {
  text-align: center;
  color: rgba(200,96,122,0.25);
  font-size: 0.55rem;
  letter-spacing: 0.6em;
  padding: 8px 0 6px;
}

/* ── FEATURED CREATORS ── */
.creators-panel { padding: 16px; }

.creators-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 7px;
  margin-top: 12px;
}

.creator-thumb {
  display: block;
  aspect-ratio: 1 / 1;
  border: 1px solid var(--border);
  border-radius: 1px;
  overflow: hidden;
  text-decoration: none;
  position: relative;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.creator-thumb:hover {
  border-color: var(--border-hi);
  box-shadow: 0 0 14px var(--glow);
}

.creator-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  filter: saturate(0.7) brightness(0.8);
  transition: filter 0.3s;
}

.creator-thumb:hover img { filter: saturate(1) brightness(1); }

.creator-caption {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(28,15,20,0.92), transparent);
  padding: 8px 4px 3px;
  text-align: center;
  font-family: 'Style Script', cursive;
  font-size: 0.75rem;
  letter-spacing: 0.04em;
  color: var(--lavender);
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.25s, transform 0.25s;
}

.creator-thumb:hover .creator-caption { opacity: 1; transform: translateY(0); }

/* ═══════════════════════════
   MAIN CONTENT
═══════════════════════════ */
.main-content {
  margin-top: 28px;
  display: flex;
  flex-direction: column;
  gap: 48px;
  padding-top: 60px;
}

.s-header {
  display: flex;
  align-items: center;
  margin-bottom: 22px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(200,96,122,0.2);
  position: relative;
}

.s-header::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0;
  width: 80px; height: 1px;
  background: linear-gradient(90deg, var(--violet), rgba(247,240,230,0.5), transparent);
}

.s-title {
  /* ↓ Cookie font for section titles: Dieties, Lorebooks, Collections, Posts */
  font-family: 'Cookie', cursive;
  font-size: 1.6rem;
  letter-spacing: 0.06em;
  color: var(--lavender);
  text-shadow: 0 0 20px var(--glow);
}

.s-title-icon { color: var(--violet); margin-right: 8px; font-size: 0.85rem; }

.s-count {
  margin-left: auto;
  font-family: 'Style Script', cursive;
  font-size: 1rem;
  color: rgba(200,96,122,0.6);
}

/* ── CANDLE ROW ── */
.candle-row {
  display: flex;
  justify-content: center;
  gap: 18px;
  margin-bottom: 18px;
  opacity: 0.4;
}

.candle-glyph {
  font-size: 0.95rem;
  animation: candle-flicker 2.4s ease-in-out infinite;
  color: var(--violet);
}
.candle-glyph:nth-child(2) { animation-delay: 0.5s; }
.candle-glyph:nth-child(3) { animation-delay: 1.0s; }
.candle-glyph:nth-child(4) { animation-delay: 1.5s; }
.candle-glyph:nth-child(5) { animation-delay: 2.0s; }

@keyframes candle-flicker {
  0%, 100% { opacity: 0.45; transform: scaleY(1); }
  30%       { opacity: 0.65; transform: scaleY(1.04); }
  60%       { opacity: 0.40; transform: scaleY(0.97); }
}

/* ═══════════════════════════
   COMPANION CARDS — FLIP
═══════════════════════════ */
.companions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
  gap: 18px;
}

.c-card { height: 240px; perspective: 1100px; cursor: pointer; }

.c-card-inner {
  position: relative;
  width: 100%; height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
}

.c-card:hover .c-card-inner,
.c-card:focus-within .c-card-inner { transform: rotateY(180deg); }

.c-front, .c-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 1px;
  overflow: hidden;
}

.c-front {
  border: 1px solid var(--border);
  box-shadow: 0 4px 20px rgba(28,15,20,0.6);
  transition: border-color 0.3s, box-shadow 0.3s;
}
.c-card:hover .c-front { border-color: var(--border-hi); }

.c-front img { width: 100%; height: 100%; object-fit: cover; display: block; }

.c-front-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 28%, rgba(0,0,0,0.15) 58%, transparent 100%),
    radial-gradient(ellipse 110% 80% at 50% 110%, rgba(0,0,0,0.28) 0%, transparent 65%);
  pointer-events: none;
  z-index: 1;
}

.c-front-name {
  position: absolute;
  bottom: 11px;
  left: 0; right: 0;
  z-index: 2;
  text-align: center;
  font-family: 'Style Script', cursive;
  font-size: 1rem;
  letter-spacing: 0.04em;
  color: var(--lavender);
  text-shadow:
    0 0 14px rgba(200,96,122,0.9),
    0 0 28px rgba(180,40,70,0.6),
    0 1px 4px rgba(0,0,0,0.95);
  padding: 0 10px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.c-front-shimmer {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(247,220,225,0.07) 55%, transparent 70%);
  pointer-events: none;
  z-index: 3;
}

.c-back {
  transform: rotateY(180deg);
  background: linear-gradient(155deg, var(--deep), var(--crypt));
  border: 1px solid var(--border-hi);
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  box-shadow: inset 0 0 30px rgba(180,40,70,0.12), inset 0 0 60px rgba(247,240,230,0.025), 0 0 24px var(--glow);
  overflow: hidden;
}

.c-back::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--violet), rgba(247,240,230,0.35), var(--violet), transparent);
}

.c-back-name {
  font-family: 'Style Script', cursive;
  font-size: 1.1rem;
  letter-spacing: 0.04em;
  color: var(--lavender);
  padding-bottom: 7px;
  border-bottom: 1px solid rgba(200,96,122,0.2);
}

.c-back-desc {
  font-family: 'Sofia', cursive;
  font-size: 0.78rem;
  color: var(--amethyst);
  line-height: 1.55;
  flex: 1;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--violet) transparent;
}

.c-back-desc::-webkit-scrollbar { width: 3px; }
.c-back-desc::-webkit-scrollbar-track { background: transparent; }
.c-back-desc::-webkit-scrollbar-thumb { background: var(--violet); border-radius: 2px; }

.c-back-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  max-height: 52px;
  overflow-y: auto;
  flex-shrink: 0;
  scrollbar-width: thin;
  scrollbar-color: var(--violet) transparent;
}

.c-back-tags::-webkit-scrollbar { width: 3px; }
.c-back-tags::-webkit-scrollbar-track { background: transparent; }
.c-back-tags::-webkit-scrollbar-thumb { background: var(--violet); border-radius: 2px; }

.c-tag {
  font-family: 'Style Script', cursive;
  font-size: 0.82rem;
  color: var(--amethyst);
  border: 1px solid rgba(200,96,122,0.28);
  padding: 1px 6px;
  background: rgba(160,30,60,0.2);
  transition: border-color 0.2s, color 0.2s;
}

.c-view-link {
  display: block;
  text-align: center;
  padding: 5px 8px;
  background: rgba(120,20,50,0.4);
  border: 1px solid rgba(200,96,122,0.45);
  color: var(--lavender);
  text-decoration: none;
  font-family: 'Style Script', cursive;
  font-size: 0.95rem;
  letter-spacing: 0.04em;
  transition: background 0.2s, box-shadow 0.2s, color 0.2s;
  flex-shrink: 0;
  margin-top: auto;
}

.c-view-link:hover {
  background: rgba(180,50,90,0.5);
  box-shadow: 0 0 12px var(--glow);
  color: var(--silver);
}

.c-fav-link {
  display: block;
