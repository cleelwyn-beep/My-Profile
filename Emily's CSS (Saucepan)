  left: 50%;
  transform: translateX(-50%);
  width: 64px; height: 14px;
  background: radial-gradient(ellipse, rgba(200,96,122,0.5), transparent 70%);
  border-radius: 50%;
  animation: chibi-shadow-pulse 4s ease-in-out infinite;
}

@keyframes chibi-shadow-pulse {
  0%, 100% { opacity: 0.55; transform: translateX(-50%) scaleX(1); }
  50%       { opacity: 0.8;  transform: translateX(-50%) scaleX(1.18); }
}

.chibi-img {
  width: 100px;
  height: auto;
  display: block;
  filter: drop-shadow(0 0 14px rgba(200,96,122,0.65)) drop-shadow(0 2px 8px rgba(0,0,0,0.8));
  animation: chibi-float 4s ease-in-out infinite;
}

@keyframes chibi-float {
  0%, 100% { transform: translateY(0px)   rotate(0deg);   }
  25%       { transform: translateY(-9px)  rotate(0.8deg); }
